export async function POST(req: Request) {
  const body = await req.json();

  const res = await fetch("http://localhost:1337/api/submissions", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      data: body,
    }),
  });

  const data = await res.json();

  return Response.json(data);
}